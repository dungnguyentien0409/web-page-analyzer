{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Inbound Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(web_analyzer_http_requests_total[1m])) by (status)" }]
    },
    {
      "title": "Inbound Latency (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(web_analyzer_http_request_duration_seconds_bucket[1m])) by (le))" }]
    },
    {
      "title": "Link Accessibility Status",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum(web_analyzer_links_checked_total) by (accessible)" }]
    },
    {
      "title": "Outbound Requests by Domain",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(rate(web_analyzer_outbound_requests_total[5m])) by (domain, status, method)" }]
    }
  ],
  "schemaVersion": 36,
  "title": "Web Page Analyzer Insight",
  "uid": "analyzer-main",
  "version": 1
}